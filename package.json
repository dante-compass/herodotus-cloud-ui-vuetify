{
  "name": "herodotus-cloud-ui-vuetify",
  "private": true,
  "type": "module",
  "version": "4.0.5.2",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "commit": "git add . && git status && git-cz",
    "push": "pnpm run commit && git push --set-upstream origin develop",
    "dev": "pnpm run --filter=@herodotus-cloud/main dev",
    "prod": "pnpm run --filter=@herodotus-cloud/main prod",
    "previewdev": "pnpm run --filter=@herodotus-cloud/main previewdev",
    "previewprod": "pnpm run --filter=@herodotus-cloud/main previewprod",
    "shared:build": "pnpm -r --filter=@herodotus/* run build"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "husky-run": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.(js|json|md|scss|ts|vue)": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "disable-devtool": "^0.3.9",
    "filesize": "^11.0.15",
    "lodash-es": "^4.18.1",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "vue": "^3.5.32",
    "vuetify": "^4.0.5"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@tsconfig/node22": "^22.0.5",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.6.0",
    "@types/nprogress": "^0.2.3",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.9.1",
    "commitizen": "^4.3.1",
    "cross-env": "^10.1.0",
    "cz-conventional-changelog": "^3.3.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.2.0",
    "eslint-config-vuetify": "4.5.0",
    "husky": "^9.1.7",
    "npm-run-all2": "^8.0.4",
    "oxfmt": "^0.45.0",
    "sass-embedded": "^1.99.0",
    "typescript": "~6.0.2",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-fonts": "^2.0.0",
    "unplugin-icons": "^23.0.1",
    "unplugin-vue-components": "^32.0.0",
    "vconsole": "^3.15.1",
    "vite": "^8.0.8",
    "vite-plugin-compression2": "^2.5.3",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-html": "^3.2.2",
    "vite-plugin-node-polyfills": "^0.26.0",
    "vite-plugin-vconsole": "^2.1.1",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vite-plugin-vuetify": "^2.1.3",
    "vue-router": "^5.0.4",
    "vue-tsc": "^3.2.6"
  }
}
